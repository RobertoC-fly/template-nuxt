{
  "name": "template-nuxt",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "test": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "start:dev": "nuxt dev --dotenv .env.development",
    "start:hml": "nuxt dev --dotenv .env.staging",
    "start:prod": "nuxt dev --dotenv .env.production",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint:check": "yarn lint:eslint && yarn lint:prettier",
    "lint:eslint": "eslint .",
    "lint:prettier": "prettier . --check",
    "lint:fix": "eslint . --fix && prettier --write --list-different .",
    "prepare": "husky"
  },
  "husky": {
    "hooks": {
      "pre-commit": "sh .husky/pre-commit"
    }
  },
  "dependencies": {
    "@nuxt/fonts": "0.14.0",
    "@nuxt/image": "2.0.0",
    "@nuxt/ui": "^4.6.1",
    "@pinia/nuxt": "0.11.3",
    "@tanstack/vue-query": "^5.99.0",
    "@vueuse/nuxt": "14.2.1",
    "axios": "^1.15.0",
    "clsx": "^2.1.1",
    "nuxt": "^4.4.2",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "tailwindcss": "^4.2.2",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e",
  "devDependencies": {
    "@nuxt/eslint": "1.15.2",
    "@nuxt/test-utils": "^4.0.2",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "happy-dom": "^20.8.9",
    "husky": "^9.1.7",
    "playwright-core": "^1.59.1",
    "prettier": "^3.8.2",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "vitest": "^4.1.4"
  }
}
